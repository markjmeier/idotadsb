DATA_SOURCE_URL=http://192.168.4.36/skyaware/data/aircraft.json
POLL_INTERVAL_SECONDS=1
HTTP_TIMEOUT_SECONDS=3
STALE_SECONDS=10
STALE_POSITION_SECONDS=10
LOW_ALTITUDE_FEET=5000
HIGH_RSSI_THRESHOLD=-10
RAPID_RATE_FPM=2000
ROTATE_TOP_N=3
ROTATE_INTERVAL_SECONDS=3
DISPLAY_MODE=closest
ENABLE_DISTANCE=false
HOME_LAT=
HOME_LON=
LOG_LEVEL=INFO
# mock | idotmatrix (PyPI bleak stack) | idotmatrix_markus (fork; see requirements-ble-markus.txt)
DISPLAY_BACKEND=mock
IDLE_MESSAGE=NO PLANES
DEBOUNCE_SECONDS=2
# Min seconds between BLE canvas pushes when only telemetry drifts (0 = visual-hash only).
DISPLAY_MIN_REFRESH_SECONDS=4
IDOTMATRIX_BLE_ADDRESS=
# Optional; if unset we try macOS Arial, Pi DejaVu/Liberation, etc.
IDOTMATRIX_FONT_PATH=

# canvas | raster = Pillow + DIY BLE. text = BLE Text grid (see app/text_grid.py).
IDOTMATRIX_RENDER=canvas
IDOTMATRIX_PIXEL_SIZE=64
IDOTMATRIX_BLE_UPLOAD_CAP=64
IDOTMATRIX_DIY_RESET=false
IDOTMATRIX_DIY_SNAP_COLORS=true
IDOTMATRIX_DIY_FORMAT=png_pypi
IDOTMATRIX_SWAP_COLORS=false
# 5–100 after BLE connect (default 100 if unset). Set 0 or skip to leave device brightness unchanged.
IDOTMATRIX_BRIGHTNESS=100
# canvas colors: R,G,B
IDOTMATRIX_FG=255,255,255
IDOTMATRIX_BG=0,0,0

# 0=static one screen (word-fit to ~8 chars on 64×64). 1=marquee shows the full line.
IDOTMATRIX_TEXT_MODE=0
IDOTMATRIX_FONT_SIZE=11
