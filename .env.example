# idotadsb — copy to `.env` and edit. Parsed by `app/config.py` (Settings.from_env).
# please keep this file and .env in sync

# =============================================================================
# Data source
# =============================================================================
DATA_SOURCE_URL=http://192.168.4.36/skyaware/data/aircraft.json
# Seconds between aircraft.json polls (15 eases load on a Pi; use 1 for snappier non-v3 modes).
POLL_INTERVAL_SECONDS=15
HTTP_TIMEOUT_SECONDS=3

# =============================================================================
# Aircraft freshness & fallback
# =============================================================================
STALE_SECONDS=10
STALE_POSITION_SECONDS=10
DEGRADED_STALE_SECONDS=60

# =============================================================================
# Display mode
# =============================================================================
# closest | rotate | v3
# v3: rotate through V3_ROTATE_TOP_N closest aircraft (hex + callsign); Live/Identity cards;
#     ADSBDB enrichment scheduled for everyone in that set each poll. No panel alert takeovers.
#     ENABLE_ADSBDB_ENRICHMENT=true for identity card data.
DISPLAY_MODE=closest

# --- rotate mode (DISPLAY_MODE=rotate) ---
ROTATE_TOP_N=3
ROTATE_INTERVAL_SECONDS=3

# --- v3 (DISPLAY_MODE=v3) ---
V3_ROTATE_TOP_N=5
# Also uses ROTATE_INTERVAL_SECONDS above: dwell time per aircraft before advancing the carousel.

# --- scoring (closest / rotate; v3 pick falls back to this when distance is unknown) ---
RSSI_WEIGHT=1
FRESHNESS_WEIGHT=2
CALLSIGN_BONUS=5
POSITION_BONUS=3
ENABLE_DISTANCE=false
DISTANCE_BONUS_MAX=15
HOME_LAT=
HOME_LON=

# =============================================================================
# Alerts (panel + low-aircraft detection; skipped when DISPLAY_MODE=v3 until emergency-only mode exists)
# =============================================================================
LOW_ALTITUDE_FEET=5000
HIGH_RSSI_THRESHOLD=-10
RAPID_RATE_FPM=2000

# =============================================================================
# App
# =============================================================================
LOG_LEVEL=INFO
# mock | idotmatrix_api_client (BLE: requirements-ble-api-client.txt).
DISPLAY_BACKEND=mock
IDLE_MESSAGE=NO PLANES
DEBOUNCE_SECONDS=2

# Min seconds between BLE pushes when only the visual fingerprint drifts (0 = hash-only).
DISPLAY_MIN_REFRESH_SECONDS=4

# =============================================================================
# iDotMatrix / BLE
# =============================================================================
IDOTMATRIX_BLE_ADDRESS=
IDOTMATRIX_FONT_PATH=
# canvas | text  (alias: raster → canvas)
IDOTMATRIX_RENDER=canvas
IDOTMATRIX_PIXEL_SIZE=64
IDOTMATRIX_BLE_UPLOAD_CAP=64
IDOTMATRIX_DIY_RESET=false
IDOTMATRIX_DIY_SNAP_COLORS=true
IDOTMATRIX_SWAP_COLORS=false
# 5–100 after connect; 0 / off / skip = do not set brightness
IDOTMATRIX_BRIGHTNESS=100
IDOTMATRIX_FG=255,255,255
IDOTMATRIX_BG=0,0,0
# text render: 0 = static fit, 1 = marquee
IDOTMATRIX_TEXT_MODE=1
IDOTMATRIX_FONT_SIZE=11

# =============================================================================
# V3 UI (DISPLAY_MODE=v3) — version3spec.md
# =============================================================================
CARD_ROTATION_SECONDS=3
# Retained for config compatibility; v3 uses ROTATE_INTERVAL_SECONDS + V3_ROTATE_TOP_N instead of hold.
AIRCRAFT_HOLD_SECONDS=60
# Optional bounds for CARD_ROTATION_SECONDS:
# MIN_CARD_ROTATION_SECONDS=2
# MAX_CARD_ROTATION_SECONDS=4
ENABLE_AIRLINE_COLORS=true
DEFAULT_TEXT_COLOR=255,255,255
DEFAULT_ACCENT_COLOR=180,200,255
ALERT_COLOR=255,80,80
CLIMB_COLOR=255,191,0
DESCENT_COLOR=80,200,255
LEVEL_COLOR=120,255,120
UNKNOWN_AIRLINE_COLOR=200,200,200

# =============================================================================
# ADSBDB enrichment (optional; v3 card B)
# =============================================================================
ENABLE_ADSBDB_ENRICHMENT=false
ADSBDB_API_BASE=https://api.adsbdb.com
ENRICHMENT_CACHE_TTL_SECONDS=1800
ENRICHMENT_REFETCH_INTERVAL_SECONDS=90
# Min seconds between enrichment round-trips (each can be 1–2 GETs). ADSBDB ~512/min; 5s is well under that.
ENRICHMENT_MIN_LOOKUP_INTERVAL_SECONDS=5
ENRICHMENT_HTTP_TIMEOUT_SECONDS=3
